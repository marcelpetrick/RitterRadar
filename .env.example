# RitterRadar — example environment configuration
# Copy to .env and adjust values before running.

# Path to sources YAML file (default: config/sources.yaml)
RITTERRADAR_SOURCES_FILE=config/sources.yaml

# SQLite database path (default: data/ritterradar.db)
RITTERRADAR_DB_PATH=data/ritterradar.db

# Number of parallel crawler workers (default: 3)
RITTERRADAR_WORKERS=3

# Nominatim geocoder contact e-mail (required by Nominatim ToS)
RITTERRADAR_GEOCODER_EMAIL=your@email.example

# Web server host (default: 127.0.0.1)
RITTERRADAR_HOST=127.0.0.1

# Web server port (default: 8000)
RITTERRADAR_PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
RITTERRADAR_LOG_LEVEL=INFO

# Re-crawl interval in hours — sources are re-queued after this many hours (default: 24)
RITTERRADAR_CRAWL_INTERVAL_HOURS=24
